    "react-dom": "^19",
    "react-router-dom": "^7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4",
    "electron": "35.2.1",
    "electron-builder": "^26",
    "electron-vite": "^3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "^6"
  }
}
