generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  engineType = "client"
  runtime    = "cloudflare"
}

generator clientNode {
  provider   = "prisma-client"
  output     = "../src/generated/prisma-node"
  engineType = "client"
  runtime    = "nodejs"
}

datasource db {
  provider = "postgresql"
}

model Skill {
  id          String   @id
  slug        String   @unique
  sourceId    String?  @unique @map("source_id")
  name        String
  description String
  summary     String?  @db.Text
  categories  Json?
  capabilities Json?
  keywords    Json?
  contentHash String?  @map("content_hash")

  // Source
  sourceType String  @default("r2") @map("source_type")
  githubRepo String? @map("github_repo")
  githubPath String? @map("github_path")
  hasScripts Boolean  @default(false) @map("has_scripts")
  hasReferences Boolean @default(false) @map("has_references")

  // Access & pricing
  visibility      String  @default("public") // "public" | "private" | "premium"
  publisherId     String? @map("publisher_id")
  orgId           String? @map("org_id")
  connectedRepoId String? @map("connected_repo_id")
  priceCents      Int?    @map("price_cents")

  // Stats
  downloads Int @default(0)

  // Vectorization
  vectorizedAt DateTime? @map("vectorized_at") @db.Timestamptz

  // Timestamps
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  publishedAt DateTime? @map("published_at") @db.Timestamptz

  chunks        SkillChunk[]
  publisher     User?           @relation("publishedSkills", fields: [publisherId], references: [id])
  org           Organization?   @relation(fields: [orgId], references: [id])
  connectedRepo ConnectedRepo? @relation(fields: [connectedRepoId], references: [id])

  @@index([githubRepo, githubPath], map: "idx_skills_github")
  @@index([downloads(sort: Desc)], map: "idx_skills_downloads")
  @@index([createdAt(sort: Desc)], map: "idx_skills_created")
  @@index([publisherId], map: "idx_skills_publisher")
  @@index([orgId], map: "idx_skills_org")
  @@map("skills")
}

// ─── Better Auth models ────────────────────────────────────────────

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false) @map("email_verified")
  image         String?
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  sessions    Session[]
  accounts    Account[]
  deviceCodes DeviceCode[]
  searchUsage SearchUsage[]

  ownedNamespaces         Namespace[]            @relation("ownedNamespaces")
  namespaceAccess         NamespaceAccess[]
  organizationMemberships OrganizationMember[]
  connectedRepos          ConnectedRepo[]
  purchases               Purchase[]
  grantedAccess           NamespaceAccess[]      @relation("grantedAccess")
  publishedSkills         Skill[]                @relation("publishedSkills")
  githubInstallations      GitHubInstallation[]

  @@map("users")
}

model Session {
  id        String   @id
  token     String   @unique
  expiresAt DateTime @map("expires_at") @db.Timestamptz
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  userId    String   @map("user_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@map("sessions")
}

model Account {
  id                    String    @id
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  accessToken           String?   @map("access_token") @db.Text
  refreshToken          String?   @map("refresh_token") @db.Text
  idToken               String?   @map("id_token") @db.Text
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at") @db.Timestamptz
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at") @db.Timestamptz
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at") @db.Timestamptz
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@map("verifications")
}

// ─── Device code flow ──────────────────────────────────────────────

model DeviceCode {
  id           String    @id @default(cuid())
  deviceCode   String    @unique @map("device_code")
  userCode     String    @unique @map("user_code")
  status       String    @default("pending") // pending | confirmed | expired
  userId       String?   @map("user_id")
  sessionToken String?   @map("session_token")
  expiresAt    DateTime  @map("expires_at") @db.Timestamptz
  lastPolledAt DateTime? @map("last_polled_at") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt], map: "idx_device_codes_expires")
  @@map("device_codes")
}

// ─── Search usage ─────────────────────────────────────────────────

model SearchUsage {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  query      String
  searchedAt DateTime @default(now()) @map("searched_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, searchedAt], map: "idx_search_usage_user_time")
  @@map("search_usage")
}

// ─── Pending skills (from CLI telemetry) ─────────────────────────

model PendingSkill {
  id          String   @id @default(cuid())
  githubUrl   String   @unique @map("github_url")
  source      String   // "cli_add", "cli_search"
  submittedAt DateTime @default(now()) @map("submitted_at") @db.Timestamptz
  status      String   @default("pending") // pending, processing, indexed, rejected

  @@map("pending_skills")
}

// ─── GitHub App Installations ───────────────────────────────────

model GitHubInstallation {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  installationId String   @map("installation_id")
  accountLogin   String?  @map("account_login")
  accountType    String?  @map("account_type")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, installationId], map: "uq_github_installations_user_installation")
  @@index([userId], map: "idx_github_installations_user")
  @@map("github_installations")
}

// ─── Vector search ────────────────────────────────────────────────

model SkillChunk {
  id         String   @id              // "{skillId}::{chunkIndex}"
  skillId    String   @map("skill_id")
  chunkId    String   @map("chunk_id")
  title      String
  text       String   @db.Text
  chunkIndex Int      @map("chunk_index")
  namespace  String   @default("public") @map("namespace")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  embedding  Unsupported("vector(1536)")?

  skill        Skill     @relation(fields: [skillId], references: [id], onDelete: Cascade)
  namespaceRef Namespace @relation(fields: [namespace], references: [id])

  @@index([skillId], map: "idx_skill_chunks_skill_id")
  @@index([namespace], map: "idx_skill_chunks_namespace")
  @@map("skill_chunks")
}

model Namespace {
  id        String   @id              // "public", "pub_tailwind", "org_acme", "usr_abc"
  name      String                    // Display name
  type      String                    // "system" | "personal" | "org" | "publisher" | "collection"
  ownerId   String   @map("owner_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  owner     User              @relation("ownedNamespaces", fields: [ownerId], references: [id])
  members   NamespaceAccess[]
  chunks    SkillChunk[]
  purchases Purchase[]

  @@map("namespaces")
}

model NamespaceAccess {
  id          String   @id @default(cuid())
  namespaceId String   @map("namespace_id")
  userId      String   @map("user_id")
  role        String   @default("reader") // "reader" | "publisher"
  grantedBy   String?  @map("granted_by")
  grantedAt   DateTime @default(now()) @map("granted_at") @db.Timestamptz

  namespace Namespace @relation(fields: [namespaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  granter   User?     @relation("grantedAccess", fields: [grantedBy], references: [id])

  @@unique([namespaceId, userId], map: "uq_namespace_access")
  @@index([userId], map: "idx_namespace_access_user")
  @@map("namespace_access")
}

// ─── Organizations ───────────────────────────────────────────────

model Organization {
  id               String   @id @default(cuid())
  slug             String   @unique
  name             String
  avatarUrl        String?  @map("avatar_url")
  billingEmail     String?  @map("billing_email")
  plan             String   @default("free") // "free" | "team" | "enterprise"
  privateSkillLimit Int     @default(5) @map("private_skill_limit")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  members        OrganizationMember[]
  connectedRepos ConnectedRepo[]
  skills         Skill[]

  @@map("organizations")
}

model OrganizationMember {
  orgId    String   @map("org_id")
  userId   String   @map("user_id")
  role     String   @default("member") // "owner" | "admin" | "member"
  joinedAt DateTime @default(now()) @map("joined_at") @db.Timestamptz

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([orgId, userId])
  @@map("organization_members")
}

// ─── Connected Repos (GitHub sync) ──────────────────────────────

model ConnectedRepo {
  id                   String    @id @default(cuid())
  orgId                String?   @map("org_id")
  userId               String?   @map("user_id")
  githubOwner          String    @map("github_owner")
  githubRepo           String    @map("github_repo")
  githubBranch         String    @default("main") @map("github_branch")
  githubInstallationId String?   @map("github_installation_id")
  skillCount           Int       @default(0) @map("skill_count")
  lastSyncedAt         DateTime? @map("last_synced_at") @db.Timestamptz
  syncStatus           String    @default("pending") @map("sync_status") // "pending" | "syncing" | "synced" | "error"
  syncError            String?   @map("sync_error")
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz

  org    Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user   User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills Skill[]

  @@unique([githubOwner, githubRepo])
  @@map("connected_repos")
}

// ─── Purchases (premium catalogs) ───────────────────────────────

model Purchase {
  id              String   @id @default(cuid())
  namespaceId     String   @map("namespace_id")
  userId          String   @map("user_id")
  priceCents      Int      @map("price_cents")
  stripePaymentId String?  @map("stripe_payment_id")
  purchasedAt     DateTime @default(now()) @map("purchased_at") @db.Timestamptz

  namespace Namespace @relation(fields: [namespaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([namespaceId, userId])
  @@map("purchases")
}
